# Copia in .env per sviluppo locale con `netlify dev`
# Su Netlify: Site settings → Environment variables

# Segreto per firmare i JWT utente (genera una stringa casuale lunga)
JWT_SECRET=

# Token CardTrader (mai nel frontend) — accetta CARDTRADER_API_TOKEN o CARDTRADER_API_KEY
CARDTRADER_API_TOKEN=

# API Key Pokémon TCG (mai nel frontend)
POKEMON_TCG_API_KEY=
